{
	"name": "@wsmy/antora-markdown-exporter",
	"version": "0.7.1-dev",
	"packageManager": "bun@1.3.13",
	"description": "Antora Assembler based Markdown exporter with semantic IR, inspection surfaces, and explicit Markdown flavor rendering",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"antora-markdown-exporter": "./bin/antora-markdown-exporter.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./extension": {
			"types": "./dist/extension/index.d.ts",
			"import": "./dist/extension/index.js",
			"require": "./dist/extension/index.cjs"
		}
	},
	"files": [
		"dist/**/*.js",
		"dist/**/*.cjs",
		"dist/**/*.d.ts",
		"bin",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup --dts --format esm,cjs --out-dir dist src/index.ts src/extension/index.ts",
		"docs:build": "node scripts/build-docs-site.mjs",
		"pdf:build": "node -e \"import('./scripts/build-docs-site.mjs').then(({ buildDocsPdf }) => buildDocsPdf(process.cwd()))\"",
		"test": "vitest run --coverage",
		"test:watch": "vitest",
		"unit": "vitest run tests/unit",
		"integration": "vitest run tests/integration",
		"reference": "vitest run tests/integration/reference-antora.test.ts",
		"inspect:report": "bun scripts/inspection-report.ts",
		"export:modules": "bun scripts/export-antora-modules.ts",
		"markdown:build": "bun scripts/export-antora-modules.ts --package-task-markdown",
		"lint": "biome check bin src tests scripts package.json biome.json tsconfig.json tsconfig.build.json vitest.config.ts",
		"fix": "biome check --write bin src tests scripts package.json biome.json tsconfig.json tsconfig.build.json vitest.config.ts",
		"format": "biome format --write bin src tests scripts package.json biome.json tsconfig.json tsconfig.build.json vitest.config.ts",
		"check": "biome check bin src tests scripts package.json biome.json tsconfig.json tsconfig.build.json vitest.config.ts && vitest run --coverage",
		"release:check": "node scripts/release-check.mjs",
		"release": "bun scripts/release.js",
		"prepublishOnly": "npm run build && npm run check && npm run release:check"
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@antora/cli": "^3.1.14",
		"@antora/site-generator": "^3.1.14",
		"@biomejs/biome": "^2.4.12",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^4.1.4",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"vitest": "^4.0.0"
	},
	"dependencies": {
		"@antora/assembler": "^1.0.0-beta.20",
		"@asciidoctor/core": "^3.0.4"
	}
}
