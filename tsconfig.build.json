{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": false,
		"outDir": "dist",
		"rootDir": "src",
		"module": "ESNext",
		"target": "ES2022",
		"types": ["node"],
		"moduleResolution": "bundler"
	},
	"include": ["src"]
}
